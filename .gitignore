# =========================
# Node & Frontend (Vite/Svelte)
# =========================
/build
/package
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
node_modules/
dist/
dist-ssr/
.svelte-kit/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env variables
.env
.env.*
!.env.example

# =========================
# Rust & Tauri Backend
# =========================
src-tauri/target/
# Note: We do NOT ignore Cargo.lock because this is an executable app, 
# and locking dependencies ensures anyone cloning it gets the exact same build.

# =========================
# AI Models & Sidecar Binaries (Crucial for our app)
# =========================
# Ignore downloaded LLM weights
*.gguf
*.bin

# Ignore the actual sidecar executables so we don't bloat the repo
# (We will instruct users to download these in the README later)
src-tauri/binaries/*
!src-tauri/binaries/.gitkeep

# =========================
# Local Databases
# =========================
# We don't want your private notes and calendar syncing to GitHub!
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# =========================
# OS & Editor Files
# =========================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?